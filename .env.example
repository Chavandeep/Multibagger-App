# Copy these into Netlify → Site configuration → Environment variables.
# Never commit real values to git or paste them in chat.

# From sharekhan.com/trading-api once you generate your API key
SHAREKHAN_API_KEY=
SHAREKHAN_SECRET_KEY=

# Only needed if Sharekhan issues you a vendor key (most personal accounts won't have one)
SHAREKHAN_VENDOR_KEY=

# Your deployed site's URL, e.g. https://your-site-name.netlify.app
# Used to send you back to the app after login completes.
APP_URL=
